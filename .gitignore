.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Obsidian plugin binaries (downloaded by setup.sh, not tracked)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/manifest.json
.obsidian/plugins/*/styles.css

# Obsidian theme files (downloaded by setup.sh, not tracked)
.obsidian/themes/

# Environment
.env
.env.local
